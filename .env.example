# APP_URL: The URL where this app is hosted.
# Set this to your deployed service URL (e.g. https://crmdsa.berocket.com.br).
# Used for self-referential links, OAuth callbacks, and API endpoints.
# IMPORTANT: the tracking pixel and unsubscribe links embedded in outgoing
# emails are built from this value — it must be the PUBLIC domain reachable
# by the lead's mail client, even when sending from a local dev session.
APP_URL="MY_APP_URL"

# GOOGLE_SERVICE_ACCOUNT_KEY: full JSON key of a Google Cloud Service Account
# with access to the Google Sheets API, pasted as a single line.
# REQUIRED for email-open tracking ("Abertura") to be written to the sheet
# 24/7: the tracking pixel endpoint (/api/track) uses it to write directly to
# the spreadsheet the moment a lead opens an email, even when nobody has the
# CRM open in a browser. Without it the server runs in degraded mode and opens
# are only recorded while someone keeps the CRM tab open.
# Setup: create a Service Account in Google Cloud Console (IAM > Service
# Accounts), enable the Google Sheets API in the project, generate a JSON key,
# and SHARE the CRM spreadsheet with the service account's client_email as
# Editor (like sharing with any user).
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com",...}'

# TRACKING_DATA_DIR (optional): directory where the server persists the
# open/unsubscribe event buffer so it survives restarts. Defaults to ./data.
# On Coolify/Docker, mount a volume at this path to survive redeploys.
# TRACKING_DATA_DIR="/data"

# Firebase project config (client-side, exposed in the browser bundle by design).
# Get these values from Firebase Console > Project Settings > General > Your apps.
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
